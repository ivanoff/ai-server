# Path to the model (absolute path or relative to the project root)
MODEL_PATH=./models/llama-2-7b-chat.gguf

# Public model id returned in API responses
MODEL_ID=llama-local

# Port for the server to run on
PORT=3000

# Default maximum number of tokens for generation
DEFAULT_MAX_TOKENS=2048

# Number of model layers to offload to GPU (0 for CPU-only)
GPU_LAYERS=0

# GPU backend: auto | cpu | cuda | vulkan | metal
GPU_BACKEND=auto

# Request timeout in milliseconds
REQUEST_TIMEOUT_MS=120000

# Maximum active generation requests at the same time
MAX_CONCURRENT_REQUESTS=2

# Maximum JSON body size accepted by Express
BODY_LIMIT=1mb

# API key for authentication (leave empty to disable auth)
API_KEY=your_api_key

# CORS settings
CORS_ENABLED=true
CORS_ORIGIN=*
CORS_CREDENTIALS=false

# Reverse proxy / security
TRUST_PROXY=false
SECURITY_HEADERS_ENABLED=true
EXPOSE_MODEL_PATH_IN_HEALTH=false

# Logging level: debug | info | warn | error
LOG_LEVEL=info
